{
  "id": "preact-htm",
  "packageName": "preact",
  "additionalPackages": ["htm"],
  "sourceEntry": "web/src/vendor/preact-htm-entry.ts",
  "outputFile": "web/static/common/js/vendor/preact-htm.js",
  "metadataFile": "web/static/common/js/vendor/preact-htm.meta.json",
  "buildCommand": [
    "bun",
    "build",
    "$SOURCE_ENTRY",
    "--target=browser",
    "--format=esm",
    "--minify",
    "--outfile",
    "$OUTPUT_FILE"
  ]
}
